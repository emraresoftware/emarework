# ═══════════════════════════════════════════════════════════════════════════
# HIVE COORDINATOR - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ─── Genel ──────────────────────────────────────────────────────────────────
APP_NAME=Hive Coordinator
VERSION=1.0.0
DEBUG=false

# ─── Sunucu ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
# Production: postgresql+asyncpg://user:password@host:5432/database
# Development: sqlite+aiosqlite:///./hive.db
DATABASE_URL=postgresql+asyncpg://hive:hive_secret@localhost:5432/hive_coordinator

# ─── Redis (Cache + Queue) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ─── Celery (Task Queue) ────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=10

# ─── Hiyerarşi ──────────────────────────────────────────────────────────────
HIERARCHY_DEPTH=10
BRANCH_FACTOR=10

# ─── Performans ─────────────────────────────────────────────────────────────
AGGREGATION_INTERVAL_SEC=30
HEARTBEAT_TIMEOUT_SEC=300
MAX_CASCADE_DEPTH=10
BATCH_REGISTER_MAX_DEPTH=5

# ─── Yük Dengeleme ──────────────────────────────────────────────────────────
OVERLOAD_THRESHOLD_PCT=90.0
REBALANCE_TRIGGER_PCT=30.0
MIN_EFFICIENCY_THRESHOLD=0.5

# ─── Mesajlaşma ─────────────────────────────────────────────────────────────
DEFAULT_MESSAGE_TTL_SEC=3600
MAX_BROADCAST_DEPTH=10
MESSAGE_RETRY_COUNT=3
MESSAGE_RETRY_DELAY_SEC=5

# ─── Güvenlik ───────────────────────────────────────────────────────────────
SECRET_KEY=change-this-in-production-use-strong-random-key
API_KEY=
ALLOWED_ORIGINS=*

# ─── Loglama ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
